# Backend & Infrastructure
# WebSSH backend URL (WebSocket endpoint)
# Note: This is a separate service from your static frontend hosting.
# Leave empty to disable the webssh command (simulated ssh still works)
VITE_WEBSSH_BACKEND_URL=ws://your-backend-server.com/ssh

# Feedback (Telegram Bot API)
# Get your token from @BotFather and your Chat ID from /getUpdates
VITE_TELEGRAM_TOKEN=your_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_chat_id_here
